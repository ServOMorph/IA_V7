    {
      "id": "adversarial_iban_zero_width",
      "difficulty": "adversarial",
      "title": "IBAN fragmenté par caractères invisibles",
      "input": "Compte : FR76\u200b3000\u200b6000\u200b0112\u200b3456\u200b7890\u200b189",
