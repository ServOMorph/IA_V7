        {"category": "iban", "value": "FR7630006000011234567890189"}
      ]
    },
    {
      "id": "facile_nir",
      "difficulty": "facile",
      "title": "Numéro de sécurité sociale",
      "input": "NIR : 1 85 07 75 108 121 45",
