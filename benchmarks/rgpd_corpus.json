        {"category": "nir", "value": "1 85 07 75 108 121 45"}
      ]
    },
    {
      "id": "facile_carte",
      "difficulty": "facile",
      "title": "Numéro de carte bancaire",
      "input": "Carte : 4539 1488 0343 6467",
