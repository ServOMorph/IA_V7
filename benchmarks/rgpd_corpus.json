{
  "version": 1,
  "description": "Corpus synthétique pour mesurer l'anonymisation déterministe de /rgpd.",
  "thresholds": {
    "minimum_exact_case_rate": 0.75,
    "minimum_literal_recall": 0.8
  },
  "required_exact_cases": [
    "facile_email",
    "facile_telephone",
    "facile_iban",
    "facile_nir",
    "facile_carte",
    "facile_ip",
    "moyen_adresse_complete",
    "moyen_nom_civilite",
    "moyen_nom_email",
    "moyen_adresse_accentuee",
    "difficile_telephone_compact",
    "difficile_telephone_points",
    "difficile_iban_espace",
    "difficile_iban_doubles_espaces",
    "difficile_email_plus",
    "tres_difficile_csv",
    "tres_difficile_fausse_ip",
    "tres_difficile_faux_numero_carte",
    "tres_difficile_plusieurs_pii",
    "adversarial_email_homoglyphes",
    "adversarial_iban_zero_width"
  ],
  "cases": [
    {
      "id": "facile_email",
      "difficulty": "facile",
      "title": "Adresse email standard",
      "input": "Contact : alice.martin@example.com",
      "expected_sensitive": [
        {"category": "email", "value": "alice.martin@example.com"}
      ]
    },
    {
      "id": "facile_telephone",
      "difficulty": "facile",
      "title": "Téléphone français espacé",
      "input": "Téléphone : 06 12 34 56 78",
