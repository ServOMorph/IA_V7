        {"category": "nom", "value": "Mme Alice Martin"},
        {"category": "email", "value": "alice@example.fr"},
        {"category": "telephone", "value": "06-12-34-56-78"}
      ]
    },
    {
      "id": "tres_difficile_fausse_ip",
      "difficulty": "très difficile",
      "title": "Version ressemblant à une IPv4",
      "input": "Version de test : 999.999.999.999",
      "expected_sensitive": [],
      "recommendation": "Valider chaque octet IPv4 entre 0 et 255 pour réduire les faux positifs."
    },
    {
      "id": "tres_difficile_faux_numero_carte",
      "difficulty": "très difficile",
      "title": "Référence à seize chiffres",
      "input": "Référence colis : 1234 5678 9012 3456",
      "expected_sensitive": [],
      "recommendation": "Appliquer au minimum un contrôle de Luhn avant de classer une suite de 16 chiffres comme carte."
    },
    {
      "id": "tres_difficile_plusieurs_pii",
      "difficulty": "très difficile",
      "title": "Trois PII dans une phrase",
      "input": "Mme Sophie Martin utilise sophie@test.fr et le 07 98 76 54 32",
      "expected_sensitive": [
        {"category": "nom", "value": "Mme Sophie Martin"},
        {"category": "email", "value": "sophie@test.fr"},
        {"category": "telephone", "value": "07 98 76 54 32"}
      ]
    },
    {
      "id": "adversarial_email_mots",
      "difficulty": "adversarial",
      "title": "Email écrit en toutes lettres",
      "input": "Contact : jean point dupont arobase exemple point fr",
      "expected_sensitive": [
        {"category": "email", "value": "jean point dupont arobase exemple point fr"}
      ],
      "recommendation": "Prévoir une normalisation optionnelle des formes « point » et « arobase », avec contrôle des faux positifs."
    },
    {
      "id": "adversarial_email_homoglyphes",
      "difficulty": "adversarial",
      "title": "Email avec ponctuation pleine chasse",
      "input": "Contact : alice＠example．fr",
      "expected_sensitive": [
        {"category": "email", "value": "alice＠example．fr"}
      ],
      "recommendation": "Normaliser Unicode en remplaçant les homoglyphes courants avant détection."
    },
    {
      "id": "adversarial_email_fragmente",
      "difficulty": "adversarial",
      "title": "Email fragmenté sur plusieurs lignes",
      "input": "Contact : alice\n@example\n.fr",
      "expected_sensitive": [
        {"category": "email", "value": "alice\n@example\n.fr"}
      ],
      "recommendation": "Définir si la recomposition interligne est acceptable avant d'ajouter ce cas à la détection."
